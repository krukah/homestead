{
  "permissions": {
    "allow": [
      "Bash(cargo check:*)"
    ],
    "defaultMode": "dontAsk"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true
  },
  "effortLevel": "high",
  "fastMode": true,
